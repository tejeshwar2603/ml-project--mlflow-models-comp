# Example environment variables for local development
# Do NOT commit your real secrets. Copy this to .env and fill in values.

# OpenAI API key for LLM calls
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# MLflow model URI
FORECAST_MODEL_URI=models:/cpu_forecast/Production

# RAG vector store / local docs
RAG_LOCAL_PATHS=README.md;ARCHITECTURE.md
RAG_VECTOR_STORE_PATH=artifacts/vector_store.pkl

# Atlassian (Confluence/Jira) integration (optional)
#ATLASSIAN_BASE_URL=https://your-company.atlassian.net
#ATLASSIAN_EMAIL=you@company.com
#ATLASSIAN_API_TOKEN=your_api_token
#CONFLUENCE_SPACE_KEY=AIOPS
#JIRA_JQL=project = AIOPS ORDER BY updated DESC
