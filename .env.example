# Example environment variables for local development
# Do NOT commit your real secrets. Copy this to .env and fill in values.

# Grok (xAI) API key for LLM calls
llma-key=REPLACE_WITH_YOUR_GROK_KEY
LLAMA_API_URL=https://api.x.ai/v1/chat/completions
AIOPS_LLM_MODEL=grok-4.3

# OpenAI API key (optional alternative)
#OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# MLflow tracking store (SQLite - MLflow 3.x deprecated the plain ./mlruns file store)
MLFLOW_TRACKING_URI=sqlite:///mlflow_tracking.db

# MLflow model URI
FORECAST_MODEL_URI=models:/cpu_forecast/Production

# Airflow REST API - used to best-effort trigger the train_and_compare_models DAG
# whenever a dataset is uploaded (see POST /datasets/upload and /datasets/{id}/train
# in api.py). Safe to leave at these defaults; if Airflow isn't running, the trigger
# just fails silently and training still happens synchronously via MLflow.
AIRFLOW_API_URL=http://localhost:8090
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# RAG vector store / local docs
RAG_LOCAL_PATHS=README.md;ARCHITECTURE.md
RAG_VECTOR_STORE_PATH=artifacts/vector_store.pkl

# Atlassian (Confluence/Jira) integration (optional)
#ATLASSIAN_BASE_URL=https://your-company.atlassian.net
#ATLASSIAN_EMAIL=you@company.com
#ATLASSIAN_API_TOKEN=your_api_token
#CONFLUENCE_SPACE_KEY=AIOPS
#JIRA_JQL=project = AIOPS ORDER BY updated DESC
